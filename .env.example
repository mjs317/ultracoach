# --- Database ---
# Neon/Supabase/local Postgres connection string
DATABASE_URL="postgresql://user:password@localhost:5432/ultracoach?schema=public"

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Optional: base URL when deployed (Vercel sets this automatically)
# AUTH_URL="http://localhost:3000"

# --- Email (OPTIONAL magic-link auth) ---
# Leave these blank to use email + password auth only.
# Fill them in with Resend / Mailgun / Postmark / any SMTP to add a
# "Send magic link" tab on the sign-in page.
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="Ultracoach <noreply@example.com>"

# --- AI providers (set at least one) ---
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# Which provider to use by default: "anthropic" | "openai"
AI_PROVIDER="anthropic"
# Model overrides (optional)
ANTHROPIC_MODEL="claude-sonnet-4-5"
OPENAI_MODEL="gpt-4.1"

# Web search was removed in MVP mode; the science reviewer now reasons
# from the LLM's training data, so no TAVILY_API_KEY / EXA_API_KEY needed.

# --- Strava OAuth (optional; enables activity sync) ---
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""

# Public URL of your deployment (used for Strava OAuth redirect and ICS feed)
APP_URL="http://localhost:3000"

# --- Optional: Upstash Redis for rate-limiting AI jobs ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
